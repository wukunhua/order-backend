<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ordering.system.mapper.OrderMapper">

    <resultMap id="BaseResultMap" type="com.ordering.system.entity.Order">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="findById" resultMap="BaseResultMap">

        SELECT * FROM `order` WHERE id = #{userId}
    </select>

    <select id="findTodayOrderList" resultMap="BaseResultMap">
        <![CDATA[
        SELECT *
        FROM `order`
        WHERE user_id = #{userId}
          AND create_time >= CURDATE()
          AND create_time < DATE_ADD(CURDATE(), INTERVAL 1 DAY)
        ]]>
    </select>

    <select id="findAllOrderList" resultMap="BaseResultMap">
        <![CDATA[
        SELECT *
        FROM `order`
        WHERE user_id = #{userId}
        ]]>
    </select>



    <select id="findByUserId" resultMap="BaseResultMap">
        SELECT * FROM `order` WHERE user_id = #{userId} ORDER BY create_time DESC
    </select>

    <insert id="insert" parameterType="com.ordering.system.entity.Order" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO `order` (user_id, create_time, update_time)
        VALUES (#{userId}, #{createTime}, #{updateTime})
    </insert>

    <update id="update" parameterType="com.ordering.system.entity.Order">
        UPDATE `order`
        SET update_time = #{updateTime}
        WHERE id = #{id}
    </update>

</mapper>
