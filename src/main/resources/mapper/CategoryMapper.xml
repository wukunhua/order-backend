<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ordering.system.mapper.CategoryMapper">

    <resultMap id="BaseResultMap" type="com.ordering.system.entity.Category">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="sort" property="sort"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="findAll" resultMap="BaseResultMap">
        SELECT * FROM category ORDER BY sort ASC, id ASC
    </select>

    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM category WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.ordering.system.entity.Category" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO category (name, sort, create_time, update_time)
        VALUES (#{name}, #{sort}, #{createTime}, #{updateTime})
    </insert>

    <update id="update" parameterType="com.ordering.system.entity.Category">
        UPDATE category
        SET name = #{name},
            sort = #{sort},
            update_time = #{updateTime}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM category WHERE id = #{id}
    </delete>

</mapper>
