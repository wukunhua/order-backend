<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ordering.system.mapper.DishMapper">

    <resultMap id="BaseResultMap" type="com.ordering.system.entity.Dish">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="category_id" property="categoryId"/>
        <result column="sort" property="sort"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="findAll" resultMap="BaseResultMap">
        SELECT * FROM dish ORDER BY category_id ASC, sort ASC, id ASC
    </select>

    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM dish WHERE id = #{id}
    </select>

    <select id="findByCategoryId" resultMap="BaseResultMap">
        SELECT * FROM dish WHERE category_id = #{categoryId} ORDER BY sort ASC, id ASC
    </select>

    <insert id="insert" parameterType="com.ordering.system.entity.Dish" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO dish (name, category_id, sort, create_time, update_time)
        VALUES (#{name}, #{categoryId}, #{sort}, #{createTime}, #{updateTime})
    </insert>

    <update id="update" parameterType="com.ordering.system.entity.Dish">
        UPDATE dish
        SET name = #{name},
            category_id = #{categoryId},
            sort = #{sort},
            update_time = #{updateTime}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM dish WHERE id = #{id}
    </delete>

</mapper>
