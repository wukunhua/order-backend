<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ordering.system.mapper.OrderItemMapper">

    <resultMap id="BaseResultMap" type="com.ordering.system.entity.OrderItem">
        <id column="id" property="id"/>
        <result column="order_id" property="orderId"/>
        <result column="dish_id" property="dishId"/>
        <result column="dish_name" property="dishName"/>
    </resultMap>

    <select id="findByOrderId" resultMap="BaseResultMap">
        SELECT * FROM order_item WHERE order_id = #{orderId}
    </select>
    <!--  分页查询用户所有菜品  -->
    <select id="findByUserIdWithPage" resultMap="BaseResultMap">
        SELECT oi.*
        FROM `order` o
        INNER JOIN order_item oi ON o.id = oi.order_id
        WHERE o.user_id = #{userId}
        LIMIT #{offset}, #{pageSize}
    </select>

    <!-- 2. 查询用户菜品总数（用于计算总页数） -->
    <select id="countByUserId" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM `order` o
                 INNER JOIN order_item oi ON o.id = oi.order_id
        WHERE o.user_id = #{userId}
    </select>

    <select id="findAll" resultMap="BaseResultMap">
        SELECT * FROM order_item WHERE order_id = #{userId} LIMIT #{pageNumer}, #{pageSize}
    </select>

    <insert id="insert" parameterType="com.ordering.system.entity.OrderItem" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO order_item (order_id, dish_id, dish_name)
        VALUES (#{orderId}, #{dishId}, #{dishName})
    </insert>

    <delete id="deleteById">
        DELETE FROM order_item WHERE id = #{id}
    </delete>

</mapper>
